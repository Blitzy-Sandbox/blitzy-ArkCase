    [x] No hardcoded sys_ids except own primary key (MD5-derived)
    [x] No hardcoded user IDs (uses javascript:gs.getUserID())
    [x] Filter uses Resolved and Closed literally (Title Case match with sys_choice_case_status)
    [x] All x_[scope]_ placeholders preserved literally
    [x] 4-space indentation
-->
<record_update table="sys_report">
    <sys_report action="INSERT_OR_UPDATE">
        <aggregate/>
        <aggregation_source/>
        <chart_size>medium</chart_size>
        <description>Agent Workspace dashboard list-widget data source. Returns rows from x_[scope]_case where assigned_agent equals the current viewer (resolved per-viewer at evaluation time via javascript:gs.getUserID()) and status is NOT IN (Resolved, Closed). Columns: number, subject, priority, status, opened_date. Per-viewer semantics deliver each user's personal "open work" queue without per-user report duplication. Replaces ArkCase's Solr-backed ActiveCaseFileByQueueService facet pattern with a native GlideRecord-backed list query. No external BI engine.</description>
        <field_list>number,subject,priority,status,opened_date</field_list>
        <filter>assigned_agent=javascript:gs.getUserID()^statusNOT INResolved,Closed</filter>
        <format/>
        <group_by/>
        <is_real_time>false</is_real_time>
        <is_scheduled>false</is_scheduled>
        <name>x_[scope]_my_open_cases</name>
        <roles/>
        <sys_class_name>sys_report</sys_class_name>
        <sys_created_by>admin</sys_created_by>
        <sys_created_on>2025-01-01 00:00:00</sys_created_on>
        <sys_id>ee04fa982b136ad35c6fe1512826f6ab</sys_id>
        <sys_mod_count>0</sys_mod_count>
        <sys_name>My Open Cases</sys_name>
        <sys_package display_value="Case Management" source="x_[scope]">x_[scope]</sys_package>
        <sys_policy/>
        <sys_scope display_value="Case Management">x_[scope]</sys_scope>
        <sys_update_name>sys_report_x_[scope]_my_open_cases</sys_update_name>
        <sys_updated_by>admin</sys_updated_by>
        <sys_updated_on>2025-01-01 00:00:00</sys_updated_on>
        <table>x_[scope]_case</table>
        <title>My Open Cases</title>
        <type>list</type>
        <user/>
    </sys_report>
</record_update>
