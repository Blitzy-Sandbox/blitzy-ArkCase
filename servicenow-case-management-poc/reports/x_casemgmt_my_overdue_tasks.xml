-->
<record_update table="sys_report">
    <sys_report action="INSERT_OR_UPDATE">
        <aggregate/>
        <aggregation_source/>
        <chart_size>medium</chart_size>
        <description>Agent Workspace dashboard list-widget data source. Returns rows from x_casemgmt_case_task where assigned_to is the current viewer, due_date is strictly before today's midnight (i.e., overdue), and status is NOT Closed. Per-viewer semantics via javascript:gs.getUserID(); date cutoff via javascript:gs.daysAgoStart(0). Columns: subject, case (renders as parent case number), due_date, status. No external BI engine; uses native GlideAggregate. The lone task-table report among eight; all seven siblings query x_casemgmt_case.</description>
        <field_list>subject,case,due_date,status</field_list>
        <filter>assigned_to=javascript:gs.getUserID()^due_date&lt;javascript:gs.daysAgoStart(0)^status!=Closed</filter>
        <format/>
        <group_by/>
        <is_real_time>false</is_real_time>
