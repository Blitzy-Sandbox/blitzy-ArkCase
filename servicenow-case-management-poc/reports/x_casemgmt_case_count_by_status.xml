<record_update table="sys_report">
    <sys_report action="INSERT_OR_UPDATE">
        <aggregate>COUNT</aggregate>
        <aggregation_source/>
        <chart_size>medium</chart_size>
        <description>Agent Workspace dashboard donut/pie widget data source. Aggregates ALL records in x_casemgmt_case grouped by the status Choice field with COUNT(*) per bucket. Six slices expected (Draft, Open, In Progress, Pending, Resolved, Closed) when seed data spans all statuses. UNFILTERED by design - shows the entire team backlog distribution, not the agent's personal queue (which is provided by the separate x_casemgmt_my_open_cases list report). Replaces ArkCase's CaseByStatusDto + Pentaho aggregation pipeline with a native GlideAggregate-backed sys_report. Same aggregation as x_casemgmt_all_cases_by_status (Manager View bar chart); different chart type and dashboard audience per AAP Section 0.4.4.</description>
        <field_list/>
        <filter/>
        <format/>
        <group_by>status</group_by>
        <is_real_time>false</is_real_time>
        <is_scheduled>false</is_scheduled>
        <name>x_casemgmt_case_count_by_status</name>
        <roles/>
        <sys_class_name>sys_report</sys_class_name>
        <sys_created_by>admin</sys_created_by>
        <sys_created_on>2025-01-01 00:00:00</sys_created_on>
        <sys_id>32ae52ab8735ea76587edee6130abc06</sys_id>
        <sys_mod_count>0</sys_mod_count>
        <sys_name>Case Count by Status</sys_name>
        <sys_package display_value="Case Management" source="x_casemgmt">x_casemgmt</sys_package>
        <sys_policy/>
        <sys_scope display_value="Case Management">x_casemgmt</sys_scope>
        <sys_update_name>sys_report_x_casemgmt_case_count_by_status</sys_update_name>
        <sys_updated_by>admin</sys_updated_by>
        <sys_updated_on>2025-01-01 00:00:00</sys_updated_on>
        <table>x_casemgmt_case</table>
        <title>Case Count by Status</title>
        <type>pie</type>
        <user/>
    </sys_report>
