<record_update table="sys_report">
    <sys_report action="INSERT_OR_UPDATE">
        <aggregate>COUNT</aggregate>
        <aggregation_source/>
        <chart_size>medium</chart_size>
        <description>Manager View dashboard bar widget data source. Aggregates ALL records in x_[scope]_case grouped by the status Choice field with COUNT(*) per bucket. Six bars expected (Draft, Open, In Progress, Pending, Resolved, Closed) when seed data spans all statuses. UNFILTERED by design - shows the entire team backlog distribution across the case lifecycle including terminal Closed cases, enabling managers to assess case throughput and lifecycle-stage saturation. Replaces ArkCase's CaseByStatusDto + Pentaho aggregation pipeline with a native GlideAggregate-backed sys_report. Same aggregation as x_[scope]_case_count_by_status (Agent Workspace donut/pie chart); different chart type and dashboard audience per AAP Section 0.4.4. Different aggregation than x_[scope]_all_cases_by_type (group by type) and x_[scope]_all_cases_by_priority (group by priority); same Manager View dashboard.</description>
        <field_list/>
        <filter/>
        <format/>
        <group_by>status</group_by>
        <is_real_time>false</is_real_time>
        <is_scheduled>false</is_scheduled>
        <name>x_[scope]_all_cases_by_status</name>
        <roles/>
        <sys_class_name>sys_report</sys_class_name>
        <sys_created_by>admin</sys_created_by>
        <sys_created_on>2025-01-01 00:00:00</sys_created_on>
        <sys_id>deeaca81d8626c9c2cc2974716efd08c</sys_id>
        <sys_mod_count>0</sys_mod_count>
        <sys_name>All Cases by Status</sys_name>
        <sys_package display_value="Case Management" source="x_[scope]">x_[scope]</sys_package>
        <sys_policy/>
        <sys_scope display_value="Case Management">x_[scope]</sys_scope>
        <sys_update_name>sys_report_x_[scope]_all_cases_by_status</sys_update_name>
        <sys_updated_by>admin</sys_updated_by>
        <sys_updated_on>2025-01-01 00:00:00</sys_updated_on>
        <table>x_[scope]_case</table>
        <title>All Cases by Status</title>
