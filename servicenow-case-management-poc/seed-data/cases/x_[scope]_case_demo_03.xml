        status   = "In Progress"  (exactly as registered in
                   ../../choices/sys_choice_case_status.xml; capital I
                   and capital P deliberate; the space between "In" and
                   "Progress" is a single ASCII space, NOT a hyphen,
                   NOT an underscore, NOT concatenated as "InProgress".
                   Per AAP Section 0.5.7 and the agent prompt's Rule 6,
                   the exact choice value is "In Progress" with the
                   embedded space)
        priority = "Medium"  (exactly as registered in
                   ../../choices/sys_choice_case_priority.xml; capital M
                   deliberate - "Medium" not "medium" or "MEDIUM"; the
