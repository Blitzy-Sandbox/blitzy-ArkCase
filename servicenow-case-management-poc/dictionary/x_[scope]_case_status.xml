        <choice_field/>
        <choice_table/>
        <column_label>Status</column_label>
        <comments>Mandatory Choice tracking case lifecycle. Values: Draft, Open, In Progress, Pending, Resolved, Closed. Default: Draft. Drives entire case state-machine via Flow Designer flows in ../flows/. Audited (audit=true) for forensic tracking. Replaces ArkCase CaseFile.status (String, defaulted to DRAFT via @PrePersist).</comments>
        <create_roles/>
        <default_value>Draft</default_value>
        <defaultsort/>
        <delete_roles/>
        <dependent/>
        <dependent_on_field/>
        <display>true</display>
        <dynamic_creation>false</dynamic_creation>
        <dynamic_creation_script/>
