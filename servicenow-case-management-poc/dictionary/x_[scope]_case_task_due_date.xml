        <choice_field/>
        <choice_table/>
        <column_label>Due Date</column_label>
        <comments>Mandatory date when the task is due. Used by the My Overdue Tasks report (filter: due_date less than Today AND status not equal to Closed). Replaces ArkCase AcmTask.dueDate (@NotNull Date).</comments>
        <create_roles/>
        <default_value/>
        <defaultsort/>
        <delete_roles/>
