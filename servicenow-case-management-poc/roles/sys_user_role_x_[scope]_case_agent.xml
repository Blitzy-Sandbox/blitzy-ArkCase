<?xml version="1.0" encoding="UTF-8"?>
<!--
    ServiceNow Update Set record-definition for the scoped role
    `x_[scope]_case_agent` inside the scoped application
    `x_[scope]`.

    This is the mid-tier operational user role for the case-management POC.
    Per AAP Section 0.5.6 (ACL Matrix), it grants ASSIGNED-ONLY ACCESS to the
    three custom tables: Create + Read (Assigned only) + Write (Assigned only)
    on x_[scope]_case, x_[scope]_case_task, and x_[scope]_case_party. The role
    CANNOT delete records. "Assigned only" is defined as cases where
    `assigned_agent = current user OR assigned_group contains current user`.

    Per AAP Section 0.5.5 (State-Machine Transition Map), this role is
    authorized to drive the operational case lifecycle (Open -> In Progress,
    In Progress -> Pending, Pending -> In Progress, In Progress -> Resolved)
    on cases where the "Assigned only" condition holds. It is NOT authorized
    to perform the Resolved -> Closed transition; that authority is reserved
    for the x_[scope]_case_manager role and enforced in
    ../flows/sub_flows/validate_closed_transition.xml.

    Semantic source-side reference (read-only, NOT byte-for-byte ported):
      - acm-services/acm-service-users/src/main/java/com/armedia/acm/services/
        users/model/ApplicationRolesConfig.java
        ArkCase's `application.roles` list pattern, where role names were
        held as plain strings bound from external configuration via the
        @ListValue("application.roles") annotation. The case_agent role
        corresponds to ArkCase's "case worker" tier in that list.
      - acm-plugins/acm-default-plugins/acm-admin-plugin/src/main/java/com/
        armedia/acm/plugins/admin/model/RolePrivilegesConstants.java
        defines the legacy `ROLE_` prefix (intentionally NOT used in the
        target; replaced by the scope prefix `x_[scope]_`).
      - acm-plugins/acm-default-plugins/acm-admin-plugin/src/main/java/com/
        armedia/acm/plugins/admin/service/RolesPrivilegesService.java
        ArkCase's role-normalization logic (uppercase,
        whitespace-to-underscore, periods-to-double-underscore, prepend
        `ROLE_`). The ServiceNow target replaces this entire mechanism with
        named scoped roles whose privileges are enforced declaratively by
        ACLs in ../acl/.

    Constraints honored (AAP Sections 0.7.1 and 0.7.2):
      - Scope-namespace exclusivity: the role's `name` is `x_[scope]_case_agent`
        (literal `[scope]` placeholder preserved per AAP convention), and the
        `sys_scope` / `sys_package` fields bind the role to the scoped
        application by `source` attribute lookup. NO global-scope writes.
      - Zero hardcoded cross-reference sys_ids: the `sys_scope` and
        `sys_package` text-node values resolve by scope source name
        (`x_[scope]`), not by literal sys_id. The `<sys_id>`
        text-node value is THIS record's own deterministic primary key
        (MD5 of the canonical role identifier `x_[scope]_case_agent`) and
        is NOT a reference to any other record.
      - No role inheritance: `<includes_roles/>` is empty/self-closing. This
        role does NOT extend or include any out-of-the-box ServiceNow role
        (e.g., admin, itil, snc_internal, personalize_dictionary,
        report_admin) and does NOT include the sibling scoped roles
        (x_[scope]_case_manager, x_[scope]_case_viewer). All privileges flow
        EXCLUSIVELY from the scoped ACLs in ../acl/ whose conditions encode
        the "Assigned only" restriction:
          - ../acl/x_[scope]_case_create_agent.xml (CREATE on x_[scope]_case)
          - ../acl/x_[scope]_case_read_agent_assigned.xml (READ-Assigned)
          - ../acl/x_[scope]_case_write_agent_assigned.xml (WRITE-Assigned)
          - ../acl/x_[scope]_case_assigned_agent_field_acl.xml (field write)
          - mirror ACLs on x_[scope]_case_task and x_[scope]_case_party
      - No PII: the `<description>` is the literal authorization summary;
        no real names, email addresses, or organization names appear.
      - Standard role (not scoped admin): `<scoped_admin>` is `false`. The
        role does NOT grant administration of the scoped application's
        metadata; scoped-app administration remains the responsibility of
        the OOB `admin` role.
      - Standard privilege level (not elevated): `<elevated_privilege>` is
        `false`. No security elevation beyond what scoped ACLs provide.
      - Not delegable: `<can_delegate>` is `false`. Role grants are managed
        through `sys_user_has_role` records, not via Delegated Admin.
      - Grantable: `<grantable>` is `true`, allowing assignment to users
        through standard role-grant records (e.g., the demo agent seed in
        ../seed-data/role_assignments/sys_user_has_role_x_[scope]_demo_agent.xml).

    The "Assigned only" restriction is NOT encoded in this role record. It
    is encoded in the ACL `condition` script of every read/write ACL that
    references this role. The canonical condition (for context only - NOT
    placed in this role file) is:
        current.assigned_agent == gs.getUserID()
        || gs.getUser().isMemberOf(current.assigned_group.toString())
    The role record only declares the role's name; the privilege gate is
    enforced by the ACL condition scripts.

    Validation Gate 3 dependency (AAP Section 0.7.3): this role is the
    central piece for "case_agent cannot access unassigned cases." The role
    record itself enables the gate; the gate's pass condition is enforced
    by the ACL conditions referencing this role's `name`.
-->
<record_update table="sys_user_role">
    <sys_user_role action="INSERT_OR_UPDATE">
        <can_delegate>false</can_delegate>
        <description>Create + read/write only on cases where current user is the assigned agent or a member of the assigned group.</description>
        <elevated_privilege>false</elevated_privilege>
        <grantable>true</grantable>
        <includes_roles/>
        <name>x_[scope]_case_agent</name>
        <scoped_admin>false</scoped_admin>
        <suffix>case_agent</suffix>
        <sys_class_name>sys_user_role</sys_class_name>
        <sys_created_by>admin</sys_created_by>
        <sys_created_on>2025-01-01 00:00:00</sys_created_on>
        <sys_id>f7c449d22a2944c6e33eddb62ca4d241</sys_id>
        <sys_mod_count>0</sys_mod_count>
        <sys_name>x_[scope]_case_agent</sys_name>
        <sys_package display_value="Case Management" source="x_[scope]">x_[scope]</sys_package>
        <sys_policy/>
        <sys_scope display_value="Case Management">x_[scope]</sys_scope>
        <sys_update_name>sys_user_role_x_[scope]_case_agent</sys_update_name>
        <sys_updated_by>admin</sys_updated_by>
        <sys_updated_on>2025-01-01 00:00:00</sys_updated_on>
    </sys_user_role>
</record_update>
